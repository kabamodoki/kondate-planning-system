# Gemini API 設定（必須）
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=your_gemini_api_key_here

# 使用するGeminiモデル（任意 - デフォルト: gemini-2.5-flash）
GEMINI_MODEL=gemini-2.5-flash

# API シークレット（任意）
# フロントエンド→バックエンド間の認証キー。生成例: openssl rand -hex 32
# Render と Vercel の両方に同じ値を設定すること。空の場合は検証スキップ（ローカル開発向け）
API_SECRET=

# バックエンドURL（Dockerローカル開発用）
# Vercel にデプロイする場合は Vercel の環境変数に API_URL=https://your-backend.onrender.com を設定
API_URL=http://localhost:8000

# Unsplash API（任意 - 料理カードに画像を表示する場合）
# https://unsplash.com/developers で取得（無料）
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=
